<?xml version="1.0" encoding="utf-8"?>
<!-- this web.config is for IIS deployment -->
<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    <handlers>
      <!-- Indicates that the server.js file is a node.js site to be handled by the iisnode module -->
      <!-- Only needed if using iisnode, but we are using ARR Reverse Proxy here -->
    </handlers>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^(https?)://" />
          </conditions>
          <action type="Rewrite" url="{C:1}://localhost:3006/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <!-- exclude node_modules directory and subdirectories from serving -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
